<style>
  .navbar {
    background-color: white;
  }

  .fa-compass {
    color: #fe424d;
    font-size: 2rem;
  }

  .nav-link {
    color: #222222 !important;
  }

  /* Search Form */
  .search-form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .search-inp {
    width: 20rem;
    border-radius: 2rem;
    padding: 0.6rem 1rem;
  }

  .search-form-mobile {
    display: none;
    width: 100%;
    padding: 0.5rem 0;
    gap: 0.5rem;
  }

  .search-form-mobile .search-inp {
    width: 100%;
    flex: 1;
  }

  .btn-search {
    background-color: #fe424d;
    color: white;
    border: none;
    border-radius: 2rem;
    padding: 0.6rem 1.2rem;
    white-space: nowrap;
  }

  .btn-search:hover {
    background-color: #e63946;
    color: white;
  }

  @media (max-width: 991px) {
    .search-form-desktop {
      display: none !important;
    }

    .search-form-mobile {
      display: flex;
    }

    .navbar-nav {
      text-align: center;
    }

    .nav-item {
      margin: 0.25rem 0;
    }

    .nav-divider {
      border-top: 1px solid #e5e5e5;
      margin: 0.5rem 0;
    }

    /* Collapsed menu floats over page content */
    .navbar-collapse.show,
    .navbar-collapse.collapsing {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: white;
      z-index: 1050;
      padding: 1rem 1.5rem;
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
      border-bottom-left-radius: 1rem;
      border-bottom-right-radius: 1rem;
    }
  }
</style>

<nav class="navbar navbar-expand-lg bg-light border-bottom sticky-top">
  <div class="container-fluid">

    <!-- Logo -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-compass"></i>
    </a>

    <!-- Toggle Button -->
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
      aria-controls="navbarNav"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar Collapse -->
    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- Left: Explore -->
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link" href="/listings">Explore</a>
        </li>
      </ul>

      <!-- Center: Desktop Search -->
      <form class="search-form search-form-desktop mx-auto" role="search">
        <input
          class="form-control search-inp"
          type="search"
          placeholder="Search destination"
        />
        <button class="btn btn-search" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
      </form>

      <!-- Mobile Search (inside menu) -->
      <form class="search-form-mobile" role="search">
        <input
          class="form-control search-inp"
          type="search"
          placeholder="Search destination"
        />
        <button class="btn btn-search" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>
      </form>

      <div class="nav-divider d-lg-none"></div>

      <!-- Right Links -->
      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <a class="nav-link" href="/listings/new">Airbnb your home</a>
        </li>

        <% if (!currUser) { %>
          <li class="nav-item">
            <a class="nav-link" href="/signup"><strong>Sign up</strong></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/login"><strong>Log in</strong></a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/logout"><strong>Log out</strong></a>
          </li>
        <% } %>
      </ul>

    </div>
  </div>
</nav>